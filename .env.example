# Health One — Environment Configuration
# Copy to .env and fill in values for local development.

# Platform Database (PostgreSQL)
PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432
PLATFORM_DB_USER=health_one
PLATFORM_DB_PASSWORD=changeme
PLATFORM_DB_NAME=health_one_platform

# Platform DB Connection String (async)
PLATFORM_DB_URL=postgresql+asyncpg://health_one:changeme@localhost:5432/health_one_platform

# Store Database Base Path
# Each store gets: {STORE_DB_BASE_PATH}/store-{code}/store.db
STORE_DB_BASE_PATH=data

# JWT Secret (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=changeme-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# LLM Provider (not used in Sprint 2; placeholder for Sprint 4)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Upload Path
UPLOAD_PATH=data/uploads
